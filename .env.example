# ─────────────────────────────────────────────────────────────────────────────
# .env.example — AuraRAG v3.1.0
# Copy to .env and fill in the values you need.
# NEVER commit the real .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider Keys (all optional — can be supplied live in the UI) ─────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=aurarag

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Session memory ────────────────────────────────────────────────────────────
SESSION_TTL_MINUTES=60

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production set to your domain: ALLOWED_ORIGINS=https://app.yourcompany.com
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_QUERY=30/minute
RATE_LIMIT_INGEST=10/minute

# ── Upload cap ────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ── Docker (injected by docker-compose for the ui service) ───────────────────
# API_BASE=http://api:8000
