# .env.example — AuraRAG v3.4
# Copy to .env and fill in your values.
# All keys are optional — users can supply them live in the Streamlit UI.

# ── LLM Provider Keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=aurarag

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Session Memory ────────────────────────────────────────────────────────────
SESSION_TTL_MINUTES=60

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ── Upload ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_QUERY=30/minute
RATE_LIMIT_INGEST=10/minute

# ── Source Snippets ───────────────────────────────────────────────────────────
SOURCE_SNIPPET_LEN=300

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ── v3.4 LangGraph Pipeline ───────────────────────────────────────────────────
# Relevance score threshold for the Document Grader (0.0–1.0)
GRADE_THRESHOLD=0.5
# Enable the Reflect/Self-Correction node (true|false)
REFLECT_ENABLED=true
# Maximum self-correction loops per query
MAX_REFLECT_LOOPS=1
# Max tokens for the Query Rewrite LLM call (lightweight — keep small)
REWRITE_MAX_TOKENS=128
# Max tokens for each Document Grader LLM call (parallel — keep small)
GRADE_MAX_TOKENS=64
