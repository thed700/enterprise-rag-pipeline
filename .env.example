# ─────────────────────────────────────────────────────────────────────────────
# .env.example — AuraRAG v3.0.0
# Copy to .env and fill in the values you need.
# Keys are optional: users can also supply them live in the Streamlit sidebar.
# NEVER commit the real .env file — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider Keys (all optional) ─────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Default Model ─────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=aurarag

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In production, set to your domain:
# ALLOWED_ORIGINS=https://app.yourcompany.com
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ── Docker / Networking ───────────────────────────────────────────────────────
# Injected automatically by docker-compose for the ui service.
# API_BASE=http://api:8000
